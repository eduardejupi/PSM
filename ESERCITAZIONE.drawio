          <mxGeometry height="30" width="400" x="920" y="50" as="geometry" />
        </mxCell>
        <mxCell id="S-9bwVPvVeq33lM2gUcA-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h3 data-path-to-node=&quot;3&quot; style=&quot;text-align: start;&quot;&gt;&lt;b data-path-to-node=&quot;3&quot; data-index-in-node=&quot;0&quot;&gt;PROVA 1 - INSERIMENTO DIARIO CLINICO&lt;/b&gt;&lt;/h3&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;4&quot; style=&quot;text-align: start;&quot;&gt;&lt;li&gt;Deve essere visualizzata la schermata iniziale &quot;PZ1&quot;.&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,1,0&quot;&gt;Cliccare sul tasto&amp;nbsp;&lt;b data-path-to-node=&quot;3,1,0&quot; data-index-in-node=&quot;19&quot;&gt;Diario Clinico&lt;/b&gt;&amp;nbsp;(tra le opzioni disponibili: Diario Clinico, Monitoraggio Manuale, Eventuali Note, Esci).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,2,0&quot;&gt;Il sistema apre la maschera di compilazione del sottoprocesso &quot;Diario Clinico&quot;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,3,0&quot;&gt;Compilare il &quot;Diario Clinico&quot; inserendo i dati richiesti.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,4,0&quot;&gt;Cliccare sul tasto&amp;nbsp;&lt;span data-path-to-node=&quot;3,4,0&quot; data-index-in-node=&quot;19&quot;&gt;CONFERMA&lt;/span&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,5,0&quot;&gt;Il sistema apre una finestra chiedendo conferma dell&#39;operazione.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,6,0&quot;&gt;Cliccare su&amp;nbsp;&lt;span data-path-to-node=&quot;3,6,0&quot; data-index-in-node=&quot;12&quot;&gt;Conferma&lt;/span&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,8,0&quot;&gt;Il sistema visualizza l&#39;esito e attende la conferma finale.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,9,0&quot;&gt;Cliccare su&amp;nbsp;&lt;span data-path-to-node=&quot;3,9,0&quot; data-index-in-node=&quot;12&quot;&gt;OK&lt;/span&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,10,0&quot;&gt;Il sistema chiude la maschera del diario e ritorna automaticamente alla schermata iniziale &quot;PZ1&quot;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;3,11,0&quot;&gt;Verificare che nella cartella specialistica il diario sia stato memorizzato correttamente.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="485" width="390" x="1210" y="1110" as="geometry" />
        </mxCell>
        <mxCell id="S-9bwVPvVeq33lM2gUcA-2" edge="1" parent="1" source="S-9bwVPvVeq33lM2gUcA-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#999900;" target="S-9bwVPvVeq33lM2gUcA-6">
